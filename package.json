{
  "name": "betravedur",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "pipeline",
    "site"
  ],
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p packages/domain/tsconfig.json --noEmit && tsc -p packages/fetch/tsconfig.json --noEmit && tsc -p pipeline/tsconfig.json --noEmit",
    "skeleton": "tsx scripts/skeleton-demo.ts",
    "backfill": "tsx pipeline/src/backfill.ts",
    "aggregate": "tsx pipeline/src/aggregate.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.1.10",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@playwright/test": "^1.61.1",
    "@protomaps/basemaps": "^5.7.2",
    "echarts": "6.1.0",
    "maplibre-gl": "^5.24.0",
    "pmtiles": "^4.4.1",
    "suncalc": "2.0.1",
    "vite": "^8.1.5"
  }
}
